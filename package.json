{
  "name": "shuttle-arena",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "npm run d1:init:local && npm run d1:seed:local",
    "dev": "cross-env USE_D1=true next dev",
    "dev:fast": "cross-env USE_D1=true next dev",
    "build": "cross-env NEXT_TELEMETRY_DISABLED=1 next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "build:cf": "cross-env NEXT_TELEMETRY_DISABLED=1 VERCEL_TELEMETRY_DISABLED=1 npx @cloudflare/next-on-pages",
    "preview:cf": "npx wrangler pages dev .vercel/output/static",
    "deploy": "npm run build:cf && npx wrangler pages deploy .vercel/output/static",
    "deploy:demo": "npm run build:cf && node scripts/deploy-demo.mjs",
    "d1:init": "npx wrangler d1 execute shuttle-arena-db --remote --file=schema.sql",
    "d1:init:demo": "npx wrangler d1 execute shuttle-arena-demo-db --remote --file=schema.sql",
    "d1:init:local": "npx wrangler d1 execute shuttle-arena-db --local --file=schema.sql",
    "d1:migrate:archived": "npx wrangler d1 execute shuttle-arena-db --remote --file=scripts/migrate-add-archived-status.sql",
    "db:seed:sqlite": "tsx src/db/seed.ts",
    "d1:seed:demo": "npx wrangler d1 execute shuttle-arena-demo-db --remote --file=scripts/seed-demo.sql",
    "d1:seed:local": "npx wrangler d1 execute shuttle-arena-db --local --file=scripts/seed-local-d1.sql"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@cloudflare/next-on-pages": "^1.13.16",
    "@mdi/js": "^7.4.47",
    "@mdi/react": "^1.6.1",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "jose": "^6.2.1",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "shadcn": "^4.0.6",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260313.1",
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "postcss": "^8.5.6",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "wrangler": "^4.73.0"
  }
}
